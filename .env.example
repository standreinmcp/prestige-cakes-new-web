# Copy to .env.local and adjust

# Admin panel (v0.2.8)
ADMIN_PASSWORD=change-me
ADMIN_SESSION_TOKEN=generate-a-random-secret-token

# Stripe (v0.2.6) — optional; without keys, card checkout uses mock redirect
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Convex (from `npx convex dev` — required on Vercel for Production + Preview)
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# Figma comments export
FIGMA_ACCESS_TOKEN=
